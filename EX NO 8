import javax.swing.*;
import java.awt.*;

public class Gender {
    public static void main(String[] args) {
        JFrame f = new JFrame("Gender");
        JRadioButton m = new JRadioButton("Male");
        JRadioButton f1 = new JRadioButton("Female");

        ButtonGroup g = new ButtonGroup();
        g.add(m); g.add(f1);

        JButton b = new JButton("Submit");
        JLabel l = new JLabel();

        b.addActionListener(e -> {
            if (m.isSelected()) l.setText("Male");
            else if (f1.isSelected()) l.setText("Female");
        });

        f.setLayout(new FlowLayout());
        f.add(m); f.add(f1); f.add(b); f.add(l);

        f.setSize(250,150);
        f.setVisible(true);
        f.setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);
    }
}
